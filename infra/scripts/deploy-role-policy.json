{
  "Version": "2012-10-17",
  "Comment": "STARTER deploy policy for the GitHub Actions role. Scoped to this project's resources; tighten further before production. Tokens __ACCOUNT_ID__ and __PROJECT__ are substituted by bootstrap-github-oidc.sh.",
  "Statement": [
    {
      "Sid": "CloudFormationProjectStacks",
      "Effect": "Allow",
      "Action": "cloudformation:*",
      "Resource": "arn:aws:cloudformation:*:__ACCOUNT_ID__:stack/__PROJECT__-*/*"
    },
    {
      "Sid": "CloudFormationReadOnly",
      "Effect": "Allow",
      "Action": [
        "cloudformation:ValidateTemplate",
        "cloudformation:ListStacks",
        "cloudformation:DescribeStacks"
      ],
      "Resource": "*"
    },
    {
      "Sid": "NetworkingAndCompute",
      "Effect": "Allow",
      "Action": "ec2:*",
      "Resource": "*"
    },
    {
      "Sid": "IamForPlatformRoles",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:GetRole",
        "iam:TagRole",
        "iam:UntagRole",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:GetRolePolicy",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:ListRolePolicies",
        "iam:ListAttachedRolePolicies",
        "iam:CreateInstanceProfile",
        "iam:DeleteInstanceProfile",
        "iam:GetInstanceProfile",
        "iam:AddRoleToInstanceProfile",
        "iam:RemoveRoleFromInstanceProfile",
        "iam:TagInstanceProfile"
      ],
      "Resource": [
        "arn:aws:iam::__ACCOUNT_ID__:role/__PROJECT__-*",
        "arn:aws:iam::__ACCOUNT_ID__:instance-profile/__PROJECT__-*"
      ]
    },
    {
      "Sid": "IamPassRoleToServices",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::__ACCOUNT_ID__:role/__PROJECT__-*",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": ["ec2.amazonaws.com", "lambda.amazonaws.com"]
        }
      }
    },
    {
      "Sid": "ArtifactStorage",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:DeleteBucket",
        "s3:PutBucketPolicy",
        "s3:GetBucketPolicy",
        "s3:DeleteBucketPolicy",
        "s3:PutEncryptionConfiguration",
        "s3:GetEncryptionConfiguration",
        "s3:PutBucketVersioning",
        "s3:GetBucketVersioning",
        "s3:PutBucketPublicAccessBlock",
        "s3:GetBucketPublicAccessBlock",
        "s3:PutBucketOwnershipControls",
        "s3:GetBucketOwnershipControls",
        "s3:PutLifecycleConfiguration",
        "s3:GetLifecycleConfiguration",
        "s3:PutBucketTagging",
        "s3:GetBucketTagging",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::__PROJECT__-*"
    },
    {
      "Sid": "LambdaArtifactObjects",
      "Comment": "`make package` uploads the packaged Go Lambda zips to the artifact bucket, and CloudFormation reads them back from it when it creates the functions.",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::__PROJECT__-*/*"
    },
    {
      "Sid": "SpotInterruptionMetrics",
      "Comment": "The Spot handlers publish their own metrics at runtime under their own role; the deploy role only needs to read them back, e.g. to confirm a deployment works.",
      "Effect": "Allow",
      "Action": ["cloudwatch:GetMetricStatistics", "cloudwatch:ListMetrics"],
      "Resource": "*"
    },
    {
      "Sid": "EventBus",
      "Effect": "Allow",
      "Action": [
        "events:CreateEventBus",
        "events:DeleteEventBus",
        "events:DescribeEventBus",
        "events:TagResource",
        "events:UntagResource",
        "events:PutRule",
        "events:DeleteRule",
        "events:DescribeRule",
        "events:PutTargets",
        "events:RemoveTargets",
        "events:ListTargetsByRule"
      ],
      "Resource": [
        "arn:aws:events:*:__ACCOUNT_ID__:event-bus/__PROJECT__-*",
        "arn:aws:events:*:__ACCOUNT_ID__:rule/__PROJECT__-*/*",
        "arn:aws:events:*:__ACCOUNT_ID__:rule/__PROJECT__-*"
      ]
    },
    {
      "Sid": "Lambda",
      "Effect": "Allow",
      "Action": [
        "lambda:CreateFunction",
        "lambda:DeleteFunction",
        "lambda:GetFunction",
        "lambda:GetFunctionConfiguration",
        "lambda:UpdateFunctionCode",
        "lambda:UpdateFunctionConfiguration",
        "lambda:AddPermission",
        "lambda:RemovePermission",
        "lambda:GetPolicy",
        "lambda:TagResource",
        "lambda:UntagResource",
        "lambda:ListVersionsByFunction"
      ],
      "Resource": "arn:aws:lambda:*:__ACCOUNT_ID__:function:__PROJECT__-*"
    },
    {
      "Sid": "Logs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:DeleteLogGroup",
        "logs:DescribeLogGroups",
        "logs:PutRetentionPolicy",
        "logs:DeleteRetentionPolicy",
        "logs:TagResource",
        "logs:UntagResource",
        "logs:ListTagsForResource"
      ],
      "Resource": [
        "arn:aws:logs:*:__ACCOUNT_ID__:log-group:/__PROJECT__/*",
        "arn:aws:logs:*:__ACCOUNT_ID__:log-group:/aws/lambda/__PROJECT__-*"
      ]
    },
    {
      "Sid": "AmiParameterLookup",
      "Effect": "Allow",
      "Action": ["ssm:GetParameter", "ssm:GetParameters"],
      "Resource": "arn:aws:ssm:*::parameter/aws/service/ami-amazon-linux-latest/*"
    }
  ]
}
